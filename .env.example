# ============================================================================
# Modelo de variáveis de ambiente. COPIE este arquivo para `.env` e preencha.
#
#   cp .env.example .env
#
# Onde achar os valores: painel do Supabase > seu projeto >
#   Project Settings > API
#     - "Project URL"      -> VITE_SUPABASE_URL
#     - "anon public" key  -> VITE_SUPABASE_ANON_KEY
#
# IMPORTANTE: o prefixo VITE_ é obrigatório para o Vite expor a variável ao front.
# NUNCA comite o arquivo .env (ele já está no .gitignore).
# ============================================================================
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
